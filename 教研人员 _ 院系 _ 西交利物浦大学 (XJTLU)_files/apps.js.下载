            $('div.has-down', $(".sub-nav")).removeClass('has-down');
            $(this).addClass('has-down');
            $(".sub-nav-box", p).slideDown();
        }
        
    })
    
    $(".nav-left-box .sub-nav div:first-child").each(function(index, element){
