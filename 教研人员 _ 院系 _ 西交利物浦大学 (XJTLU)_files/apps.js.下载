    function changebanner(params) {
        var containers = document.querySelectorAll('.mian-container')
        if(containers.length<1){return false}
        var strArr = []
        for(var i = 0;i<containers.length;i++){
            strArr.push(containers[i].innerHTML);
        }
        // for (let item of containers) {
        //     console.log(item.innerHTML)
        //     strArr.push(item.innerHTML);
        // }
        var AbannerData = strArr[2]
        strArr.splice(2, 1)
        strArr.unshift(AbannerData)
        
        for (var id in strArr) {
            containers[id].innerHTML = strArr[id]
        }
    }
    
    var timer = $("#timer").attr("data-timer");
    changebanner()
    if(timer){
        setInterval(function (){
            changebanner()
            document.querySelector(".mian-container").classList.add("clears")
        }, timer);
    }

    var header = document.querySelector('.left-col');
    if (header) {
        var origOffsetY = document.querySelector('.left-right-path').offsetTop - 90;
        var clone = document.querySelector('#leftClone')
        
        function onScroll(e) {
            window.pageYOffset >= origOffsetY ? header.classList.add('sticky') : header.classList.remove('sticky');
            window.pageYOffset >= origOffsetY ? clone.style.display = 'block' : clone.style.display = 'none';
        }
        document.addEventListener('scroll', onScroll);
    }
    
    if ($(".slider-item").length) {
        $(".slider-item").on('click', function (e) {
            var index = $(this).index()
            $(".slider-item").map(function () {
                if ($(this).index() < index) {
                    $(this).addClass('coooocoo')
                } else {
                    $(this).removeClass('coooocoo')
                }
            })
            // $(".slider-item").lt(index).addClass('bg-co')
            e.preventDefault();
            $(this).siblings('').removeClass('active');
            $(this).addClass('active')
        })
    }
    
    if ($('.ui-controls01').length) {
        var num = 0;
        var totalNum = $('.banner-main-img01 ul li').length
        $('.ui-controls01 ul li').click(function () {
            $(this).addClass('current').siblings().removeClass('current');
            $('.banner-main-img01 ul li').eq($(this).index()).fadeIn(300);
            $('.banner-main-img01 ul li').eq($(this).index()).siblings().fadeOut(300);
            num = $(this).index();
        })
        var myfn = function () {
            $('.ui-controls01 ul li').eq(num).addClass('current').siblings().removeClass('current');
            $('.banner-main-img01 ul li').eq(num).fadeIn(300);
            $('.banner-main-img01 ul li').eq(num).siblings().fadeOut(300);
        }
        $('.ui-next01').click(function () {
            num++;
            if (num >= totalNum) {
                num = 0;
            }
            myfn();
        })
        $('.ui-prev01').click(function () {
            num--;
            if (num < 0) {
                num = totalNum - 1;
            }
            myfn();
        })
        var timer01 = null;
    
        timer01 = setInterval(function () {
            num++;
            if (num >= totalNum) {
                num = 0;
            }
            myfn();
        }, 3000)
    
        $('.lunbo01').hover(function () {
            clearInterval(timer01);
        }, function () {
            timer01 = setInterval(function () {
                num++;
                if (num >= totalNum) {
                    num = 0;
                }
                myfn();
            }, 3000)
        });
    }
    
    if ($(".module-box").length) {
        $(".module-box").click(function (e) {
            $(this).siblings().find('.down-slide-box').removeClass('showheight')
            $(this).siblings().find('.left-plus').removeClass('mins-icon')
        
            var dsb = $(this).find('.down-slide-box')
            var icon = $(this).find('.left-plus')
            if (dsb.hasClass("showheight")) {
                // dsb.show()
                dsb.removeClass('showheight')
                icon.removeClass('mins-icon')
            } else {
                // dsb.hide()
                dsb.addClass('showheight')
                icon.addClass('mins-icon')
            }
        
        });
    }
    
    
    if ($(".jump-item").length) {
        $('.jump-item').on('click', function (e) {
            e.preventDefault();
            e.stopImmediatePropagation();
        
            var target = $(e.currentTarget).attr('data-target');
            var target_offset = $('#' + target).offset().top;
            var header_height = $('.header').height();
            $('html, body').animate({scrollTop: target_offset - header_height});
        });
    }
    if ($(".m-title").length) {
        $(".m-title").click(function (){
            if (!$("#downSLIde").hasClass('show')) {
                $("#downSLIde").addClass("show")
                $("#downSLIde").show()
            } else {
                $("#downSLIde").removeClass("show")
                $("#downSLIde").hide()
            }
            
        })
    }
    if ($(".qa-title").length) {
        $(".qa-title").click(function () {
            $(".qa-title").toggleClass("plus-icon")
            $("#formQa").toggleClass('hideForm')
        })
