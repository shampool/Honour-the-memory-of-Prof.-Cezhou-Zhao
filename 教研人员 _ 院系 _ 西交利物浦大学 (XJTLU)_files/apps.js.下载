$(function(){
    
    $('.header .jmenu .jm-dropdown > a').on('click', function (e) {
        e.preventDefault();
        e.stopPropagation();
        var p = $(this).closest('.jm-dropdown');
        if (!p) return false;
        if (p.hasClass('jm-open')) {
            $('.header .jmenu .jm-dropdown').removeClass('jm-open');
        } else {
            $('.header .jmenu .jm-dropdown').removeClass('jm-open');
            p.addClass('jm-open');
            $('body').one('click', function() {
                $('.header .jmenu .jm-dropdown').removeClass('jm-open');
            });
        }
    });
    $('#mobile-menu').on('click', function () {
        $(this).toggleClass('active');
        $('#mobile-nav').slideToggle(200);
        
        if ($('#mobile-search').hasClass('active')) {
            $('#mobile-search').removeClass('active');
            $('#top .site-search').slideUp(200);
        }
    });
    
    $('#mobile-search').on('click', function () {
        console.log(666)
        $(this).toggleClass('active');
        $('.site-search').slideToggle(200);
        
        if ($('#mobile-menu').hasClass('active')) {
            $('#mobile-menu').removeClass('active');
            $('#mobile-nav').slideUp(200);
        }
    });
    
    $('#mobile-nav > ul > li > a').on('click', function (e) {
        e.preventDefault();
        
        if ($(this).siblings('ul').length) {
            if ($(this).hasClass('active')) {
                $(this).removeClass('active');
                $(this).siblings('ul').slideUp();
            } else {
                $('#mobile-nav > ul > li > a').removeClass('active');
                $('#mobile-nav > ul > li > ul').slideUp();
                $(this).addClass('active');
                $(this).siblings('ul').slideDown();
            }
        } else {
            window.location.href = $(this).attr('href');
        }
    });
    
    $("#showNvs").click(function (){
        if ($(".after-search").hasClass('showit')) {
            $(".after-search").removeClass('showit')
            $(".before-search").show();
        } else {
            $(".after-search").addClass('showit')
            $(".before-search").hide();
        }
        
        $(".search-nav-bar").slideToggle()
    })
    
